---
interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en" class="bg-white text-zinc-900">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="A demonstration of Coma (CSV) vs JSON streaming."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen font-sans antialiased selection:bg-black/10 selection:text-black">
    <main class="max-w-7xl mx-auto p-6 md:p-12">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  :root {
    --font-sans:
      "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
      Arial, sans-serif;
  }

  body {
    font-family: var(--font-sans);
  }

  /* Custom scrollbar for raw output panes */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.03);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.2);
  }
</style>
